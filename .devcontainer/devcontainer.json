{
    "name": "tricycler-dev",
    "build": {
        "dockerfile": "../workshop/docker/Dockerfile.dev",
        "context": ".."
    },
    "workspaceFolder": "/app",
    "remoteUser": "appuser",
    "remoteEnv": {
        "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
    },

    // Runs once on first container creation — detects a fresh template clone
    // and runs the rename wizard if needed.
    "onCreateCommand": "bash workshop/scripts/rename.sh",

    // Keep the container running when the VS Code window closes.
    "shutdownAction": "none",

    "customizations": {
        "vscode": {
            "extensions": [
                // TypeScript / Next.js
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "bradlc.vscode-tailwindcss",
                // Prisma
                "Prisma.prisma",
                // Git
                "eamodio.gitlens"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "files.trimTrailingWhitespace": true,
                "[prisma]": {
                    "editor.defaultFormatter": "Prisma.prisma"
                }
            }
        }
    },

    // Next.js dev server + PostgreSQL sidecar
    "forwardPorts": [3000, 5432],
    "portsAttributes": {
        "3000": {
            "label": "Next.js",
            "onAutoForward": "openBrowser"
        },
        "5432": {
            "label": "PostgreSQL",
            "onAutoForward": "silent"
        }
    }
}
