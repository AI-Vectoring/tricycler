# ==============================================================================
# Dockerfile.dev — DEVELOPMENT ENVIRONMENT
# ==============================================================================
# Base: node:22-bookworm (Debian 12, full) — best tool support for Node.js dev.
# Goal: Fast iteration. TypeScript runs via ts-node/next dev. No compile step.
#
# Source: VS Code "Clone Repository in Container Volume" clones from GitHub
#         directly into a Docker volume and mounts it into this container.
#         There are no local files to copy — edit inside the container via VS Code.
#
# User: appuser (non-root) — mirrors production to catch permission bugs early.
# ==============================================================================

FROM node:22-bookworm

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    LANGUAGE=C.UTF-8 \
    TZ=UTC

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Version control
    git \
    ca-certificates \
    curl \
    # Editors (lightweight, for quick edits inside the container)
    vim \
    nano \
    # PostgreSQL client — connect to external Postgres (sidecar or remote)
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm globally
RUN npm install -g pnpm

RUN groupadd -g 1000 appuser && \
    useradd -u 1000 -g appuser -m -s /bin/bash appuser

WORKDIR /app
RUN chown -R appuser:appuser /app

USER appuser

ENTRYPOINT ["/bin/bash"]
