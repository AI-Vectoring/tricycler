# VERSIONS — Pinned dependency versions for all containers.
#
# Update these when you want to upgrade the runtime.
# After updating, run: make build-base && make prod
#
# To check for new Node.js LTS releases: https://nodejs.org/en/about/previous-releases
# To check for new pnpm releases:        https://github.com/pnpm/pnpm/releases

# Node.js LTS version — used in all Dockerfiles as the base image tag.
NODE_VERSION=22

# pnpm version — installed globally in the builder-base image.
PNPM_VERSION=9
